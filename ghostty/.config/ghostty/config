font-family = ComicCode Nerd Font
theme = tokyonight
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard
keybind = ctrl+r>c=reload_config
keybind = ctrl+s>k=goto_split:top
keybind = ctrl+s>j=goto_split:bottom
keybind = ctrl+s>h=goto_split:left
keybind = ctrl+s>l=goto_split:right
keybind = ctrl+s>shift+2=new_split:down
keybind = ctrl+s>shift+5=new_split:right
keybind = ctrl+s>a=select_all
keybind = ctrl+s>t=new_tab
keybind = ctrl+shift+l=next_tab
keybind = ctrl+shift+h=previous_tab
keybind = ctrl+s>c=close_surface

